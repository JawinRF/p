<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.prismshield">

    <!-- ── Permissions ───────────────────────────────────────────────────── -->

    <!-- HTTP sidecar (localhost:8766) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Clipboard monitoring -->
    <uses-permission android:name="android.permission.READ_CLIPBOARD_IN_BACKGROUND" />

    <!-- Notification listener (must also be granted manually in Settings) -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions"
        xmlns:tools="http://schemas.android.com/tools"/>

    <!-- Accessibility service for WindowContextBridge -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions"
        xmlns:tools="http://schemas.android.com/tools"/>

    <!-- ── Application ───────────────────────────────────────────────────── -->
    <application
        android:name=".PrismApp"
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="PRISM Shield"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrismShield">

        <!-- Main dashboard activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Background sidecar service ────────────────────────────────── -->
        <service
            android:name=".PrismShieldService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ── Notification listener ──────────────────────────────────────── -->
        <!--
            User must grant via:
            Settings > Apps > Special app access > Notification access > PRISM Shield
        -->
        <service
            android:name=".PrismNotificationListener"
            android:exported="true"
            android:label="PRISM Notification Scanner"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- ── Accessibility service (for WindowContextBridge) ────────────── -->
        <!--
            User must grant via:
            Settings > Accessibility > PRISM Shield
        -->
        <service
            android:name=".PrismAccessibilityService"
            android:exported="true"
            android:label="PRISM Accessibility Scanner"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>
</manifest>
